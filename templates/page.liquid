<section class="container" style="padding: 60px 20px;">
  <div class="glass-panel" style="padding: 40px; max-width: 800px; margin: 0 auto;">
    <h1 style="font-family: var(--font-title); margin-bottom: 25px; border-bottom: 1px solid var(--color-border-glass); padding-bottom: 15px;">{{ page.title }}</h1>
    <div class="page-content" style="color: var(--color-text-muted); line-height: 1.8;">
      {{ page.content }}
    </div>
  </div>
</section>
