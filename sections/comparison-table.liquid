<section class="comparison-section">
  <div class="container">
    <h2 class="section-title">Tabla de Comparación</h2>
    <p class="section-subtitle">Descubre por qué ZBC Max Premium es la mejor opción frente a otras alternativas</p>
    
    <div class="comparison-table-wrapper glass-panel" style="padding: 20px;">
      <table class="comp-table">
        <thead>
          <tr>
            <th class="comp-feature">Características</th>
            <th class="brand-col">ZBC Max (Yo)</th>
            <th>Otras Marcas</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="comp-feature">Cancelación Activa de Ruido (ANC) Real</td>
            <td class="brand-col">{% render 'icon-check-cross', type: 'check' %}</td>
            <td>{% render 'icon-check-cross', type: 'cross' %}</td>
          </tr>
          <tr>
            <td class="comp-feature">Batería de larga duración (+30 horas)</td>
            <td class="brand-col">{% render 'icon-check-cross', type: 'check' %}</td>
            <td>{% render 'icon-check-cross', type: 'cross' %}</td>
          </tr>
          <tr>
            <td class="comp-feature">Puerto de Carga USB-C Moderno (Ver2)</td>
            <td class="brand-col">{% render 'icon-check-cross', type: 'check' %}</td>
            <td>{% render 'icon-check-cross', type: 'cross' %}</td>
          </tr>
          <tr>
            <td class="comp-feature">Garantía de 30 Días Garantizada</td>
            <td class="brand-col">{% render 'icon-check-cross', type: 'check' %}</td>
            <td>{% render 'icon-check-cross', type: 'cross' %}</td>
          </tr>
          <tr>
            <td class="comp-feature">Audio Espacial 3D y Sonido Envolvente</td>
            <td class="brand-col">{% render 'icon-check-cross', type: 'check' %}</td>
            <td>{% render 'icon-check-cross', type: 'cross' %}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparison Table",
  "settings": []
}
{% endschema %}
