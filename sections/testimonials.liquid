<section class="testimonials-section">
  <div class="container">
    <h2 class="section-title">Testimonios de Clientes</h2>
    <p class="section-subtitle">Lo que dicen quienes ya disfrutan de la experiencia ZBC Max</p>
    
    <div class="testimonials-grid">
      <!-- Testimonio 1 -->
      <div class="testimonial-card glass-panel hover-3d">
        <div class="testimonial-header">
          {% render 'icon-stars' %}
