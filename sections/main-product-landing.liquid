{%- assign product = section.settings.selected_product -%}
{%- assign product_title = product.title | default: "ZBC Max Premium" -%}
{%- assign default_price = product.price | money | default: "€39,90" -%}
{%- assign default_compare_price = product.compare_at_price | money | default: "€79,90" -%}

<section class="container" style="padding-top: 20px;" data-product-id="{{ product.id }}">
  <div class="landing-product-grid">
    
    <!-- Columna Izquierda: Galería de Imágenes -->
    <div class="product-gallery">
      <div class="glass-panel hover-3d" style="padding: 20px; display: flex; align-items: center; justify-content: center; position: relative;">
        <!-- Badge de descuento flotante -->
        <span class="discount-badge" style="position: absolute; top: 15px; left: 15px; z-index: 5;">
          {%- if product.compare_at_price > product.price -%}
            {{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}% OFF
          {%- else -%}
            OFERTA
          {%- endif -%}
        </span>
        
        <div class="main-image-container">
          {%- if product.media.size > 0 -%}
            <img id="product-main-image" class="hover-3d-child" src="{{ product.media[0] | img_url: '800x800' }}" alt="{{ product_title }}" width="600" height="600" loading="eager">
          {%- else -%}
            <img id="product-main-image" class="hover-3d-child" src="{{ 'airpods_max_main.png' | asset_url }}" alt="{{ product_title }}" width="600" height="600" loading="eager">
          {%- endif -%}
        </div>
      </div>
      
      <!-- Miniaturas / Galería -->
      <div class="thumbnail-list">
        {%- if product.media.size > 0 -%}
          {%- for media in product.media limit: 5 -%}
            <div class="thumbnail-item {% if forloop.first %}active{% endif %}" data-image-src="{{ media | img_url: '800x800' }}">
              <img src="{{ media | img_url: '150x150' }}" alt="{{ media.alt | escape }}" width="70" height="70" loading="lazy">
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="thumbnail-item active" data-image-src="{{ 'airpods_max_main.png' | asset_url }}">
            <img src="{{ 'airpods_max_main.png' | asset_url }}" alt="Vista Principal" width="70" height="70" loading="lazy">
          </div>
          <div class="thumbnail-item" data-image-src="{{ 'airpods_max_gray.png' | asset_url }}">
            <img src="{{ 'airpods_max_gray.png' | asset_url }}" alt="Deep Space Gray" width="70" height="70" loading="lazy">
          </div>
        {%- endif -%}
      </div>
    </div>
    
    <!-- Columna Derecha: Información del Producto -->
    <div class="product-info-panel">
      <div class="product-meta">
        <h1 class="product-title">{{ product_title }}</h1>
        
        <div class="product-reviews">
          {% render 'icon-stars' %}
          <span class="review-count">{{ section.settings.review_text }}</span>
        </div>
        
        <div class="price-box">
          <span id="product-current-price-display" class="current-price" data-raw-price="{{ product.price | default: 3990 }}">{{ default_price }}</span>
          <span id="product-compare-price-display" class="old-price">{{ default_compare_price }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="discount-badge">{{ section.settings.save_text }} {{ product.compare_at_price | minus: product.price | money }}</span>
          {%- endif -%}
        </div>
      </div>
      
      <!-- Bullet list (Características) -->
      <ul class="product-bullet-list">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <li>
                <span style="color: {{ block.settings.icon_color }}; display: flex;">
                  <!-- Icono de check simple por defecto -->
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <li><span style="color: #10b981; display: flex;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span><span>Envío GRATIS Solo Hoy</span></li>
          <li><span style="color: #f59e0b; display: flex;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg></span><span>Garantía de Satisfacción</span></li>
        {%- endif -%}
      </ul>

      <!-- JSON para datos de producto en JS -->
      {%- if product != blank -%}
      <script id="product-json-data" type="application/json">
        {{ product | json }}
      </script>
      {%- endif -%}

      <!-- Formulario de Compra -->
      <form action="/cart/add" method="post" enctype="multipart/form-data" id="landing-add-to-cart-form">
        <input type="hidden" name="quantity" id="product-quantity-input" value="2">
        <input type="hidden" name="id" id="main-product-variant-id" value="{{ product.variants.first.id }}">
        
        <!-- Compra más, gasta menos (Sección de Ofertas) -->
        <div class="volume-discount-container">
          <div class="volume-discount-title">{{ section.settings.offer_title_main }}</div>
          
          <!-- Oferta 1: 1 unidad -->
          <div class="offer-option" data-quantity="1" data-multiplier="1" data-discount="1.0">
            <div class="offer-header">
              <div class="offer-radio">
                <span class="radio-circle"></span>
                <div>
                  <span class="offer-title">{{ section.settings.offer_1_title }}</span>
                  <span class="offer-subtitle">{{ section.settings.offer_1_subtitle }}</span>
                </div>
              </div>
              <div class="offer-price-info">
                <span class="offer-price dynamic-price-1x">€--</span>
                <div class="offer-compare-price dynamic-compare-1x">€--</div>
              </div>
            </div>
            
            {%- if product.has_only_default_variant == false -%}
              <div class="offer-selectors" style="display: none;">
                <div class="selector-row">
                  <label>Unidad 1:</label>
                  {%- for option in product.options_with_values -%}
                    <select class="offer-select dynamic-variant-select" data-unit="1" data-option-index="option{{ forloop.index }}">
                      {%- for value in option.values -%}
                        <option value="{{ value | escape }}">{{ option.name }}: {{ value | escape }}</option>
                      {%- endfor -%}
                    </select>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </div>
          
          <!-- Oferta 2: 2 unidades (Preseleccionada) -->
          <div class="offer-option active" data-quantity="2" data-multiplier="2" data-discount="0.8">
            <span class="offer-badge popular">{{ section.settings.offer_2_badge }}</span>
            <div class="offer-header">
              <div class="offer-radio">
                <span class="radio-circle"></span>
                <div>
                  <span class="offer-title">{{ section.settings.offer_2_title }} <span style="font-size:0.8rem; background:rgba(16, 185, 129, 0.15); color:#10b981; padding:2px 6px; border-radius:4px; margin-left:5px;">{{ section.settings.discount_badge_text }}</span></span>
                  <span class="offer-subtitle">{{ section.settings.offer_2_subtitle }}</span>
                </div>
              </div>
              <div class="offer-price-info">
                <span class="offer-price dynamic-price-2x">€--</span>
                <div class="offer-compare-price dynamic-compare-2x">€--</div>
              </div>
            </div>
            
            {%- if product.has_only_default_variant == false -%}
              <div class="offer-selectors" style="display: grid;">
                <div class="selector-row">
                  <label>Unidad 1:</label>
                  {%- for option in product.options_with_values -%}
                    <select class="offer-select dynamic-variant-select" data-unit="1" data-option-index="option{{ forloop.index }}">
                      {%- for value in option.values -%}
                        <option value="{{ value | escape }}">{{ option.name }}: {{ value | escape }}</option>
                      {%- endfor -%}
                    </select>
                  {%- endfor -%}
                </div>
                <div class="selector-row">
                  <label>Unidad 2:</label>
                  {%- for option in product.options_with_values -%}
                    <select class="offer-select dynamic-variant-select" data-unit="2" data-option-index="option{{ forloop.index }}">
                      {%- for value in option.values -%}
                        <option value="{{ value | escape }}">{{ option.name }}: {{ value | escape }}</option>
                      {%- endfor -%}
                    </select>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </div>
          
          <!-- Oferta 3: 3 unidades -->
          <div class="offer-option" data-quantity="3" data-multiplier="3" data-discount="0.7">
            <span class="offer-badge best">{{ section.settings.offer_3_badge }}</span>
            <div class="offer-header">
              <div class="offer-radio">
                <span class="radio-circle"></span>
                <div>
                  <span class="offer-title">{{ section.settings.offer_3_title }} <span style="font-size:0.8rem; background:rgba(16, 185, 129, 0.15); color:#10b981; padding:2px 6px; border-radius:4px; margin-left:5px;">{{ section.settings.discount_badge_text }}</span></span>
                  <span class="offer-subtitle">{{ section.settings.offer_3_subtitle }}</span>
                </div>
              </div>
              <div class="offer-price-info">
                <span class="offer-price dynamic-price-3x">€--</span>
                <div class="offer-compare-price dynamic-compare-3x">€--</div>
              </div>
            </div>
            
            {%- if product.has_only_default_variant == false -%}
              <div class="offer-selectors" style="display: none;">
                <div class="selector-row">
                  <label>Unidad 1:</label>
                  {%- for option in product.options_with_values -%}
                    <select class="offer-select dynamic-variant-select" data-unit="1" data-option-index="option{{ forloop.index }}">
                      {%- for value in option.values -%}
                        <option value="{{ value | escape }}">{{ option.name }}: {{ value | escape }}</option>
                      {%- endfor -%}
                    </select>
                  {%- endfor -%}
                </div>
                <div class="selector-row">
                  <label>Unidad 2:</label>
                  {%- for option in product.options_with_values -%}
                    <select class="offer-select dynamic-variant-select" data-unit="2" data-option-index="option{{ forloop.index }}">
                      {%- for value in option.values -%}
                        <option value="{{ value | escape }}">{{ option.name }}: {{ value | escape }}</option>
                      {%- endfor -%}
                    </select>
                  {%- endfor -%}
                </div>
                <div class="selector-row">
                  <label>Unidad 3:</label>
                  {%- for option in product.options_with_values -%}
                    <select class="offer-select dynamic-variant-select" data-unit="3" data-option-index="option{{ forloop.index }}">
                      {%- for value in option.values -%}
                        <option value="{{ value | escape }}">{{ option.name }}: {{ value | escape }}</option>
                      {%- endfor -%}
                    </select>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>

        <!-- Botones de compra -->
        <button type="submit" name="add" id="main-add-to-cart-btn" class="add-to-cart-btn">
          {{ section.settings.add_to_cart_text }}
        </button>
        
        <button type="button" class="paypal-btn">
          <span>Pagar con</span>
          <img src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg" alt="PayPal" width="70" height="20">
        </button>
      </form>

      <!-- Pasarelas de Pago Confianza -->
      <div class="payment-trust-container">
        <div class="payment-trust-title">{{ section.settings.payment_trust_title }}</div>
        <div class="payment-icons">
          {%- assign payment_blocks = section.blocks | where: 'type', 'payment_icon' -%}
          {%- if payment_blocks.size > 0 -%}
            {%- for block in payment_blocks -%}
              {%- if block.settings.icon != blank -%}
                <img src="{{ block.settings.icon | img_url: '100x' }}" alt="Payment Icon" height="24" style="object-fit: contain; width: auto; max-width: 50px;">
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <!-- Logos de tarjetas por defecto -->
            <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/american_express-38acc224cd690caecc14757b336e1f03b6adac73b2d2136e0a4f5f6c2fc01a1d.svg" alt="Amex" width="38" height="24">
            <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/apple_pay-f6db0077dae8de79dbda4b1d02c5c93c4e363eb2b069d76c725ccdb39ff715a3.svg" alt="Apple Pay" width="38" height="24">
            <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/google_pay-c50a1cbc49fb3437cea0a0148c42d3cac5c3fa8f16f5c8724773663a8a3a0e63.svg" alt="Google Pay" width="38" height="24">
            <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/master-962ec95e1e13d92fead207921a731d147fa4d3f3f8c0dafbfe59d288ca7a5dc0.svg" alt="Mastercard" width="38" height="24">
            <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/paypal-d5f35cdbc263e64d95975d9c282be7249bfa4a3459c3d4a6e87c0cc2e88a6d65.svg" alt="Paypal" width="38" height="24">
            <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/visa-ac2325c187444e2e288165796245085e94f923b7b9f305f8ee4a93822d6402ec.svg" alt="Visa" width="38" height="24">
          {%- endif -%}
        </div>
      </div>

      <!-- Estimación de envío real de 4 a 7 días -->
      <div class="shipping-timeline">
        <div class="timeline-steps">
          <div class="timeline-step active">
            <div class="timeline-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            </div>
            <div id="shipping-order-date" class="timeline-date">Ene 4th</div>
            <div class="timeline-label">{{ section.settings.shipping_step_1 }}</div>
          </div>
          
          <div class="timeline-step">
            <div class="timeline-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            </div>
            <div id="shipping-ready-date" class="timeline-date">Ene 5th - Ene 6th</div>
            <div class="timeline-label">{{ section.settings.shipping_step_2 }}</div>
          </div>
          
          <div class="timeline-step active">
            <div class="timeline-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </div>
            <div id="shipping-delivery-date" class="timeline-date">Ene 14th - Ene 16th</div>
            <div class="timeline-label">{{ section.settings.shipping_step_3 }}</div>
          </div>
        </div>
      </div>

      <!-- Testimonio del producto rápido -->
      <div class="single-testimonial">
        <p class="testimonial-text">{{ section.settings.testimonial_text }}</p>
        <p class="testimonial-author">{{ section.settings.testimonial_author }}</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Producto Principal",
  "settings": [
    {
      "type": "header",
      "content": "Producto"
    },
    {
      "type": "product",
      "id": "selected_product",
      "label": "Seleccionar Producto",
      "info": "Elige el producto que deseas mostrar en esta landing page."
    },
    {
      "type": "header",
      "content": "Reseñas y Etiquetas"
    },
    {
      "type": "text",
      "id": "review_text",
      "label": "Texto de Reseñas",
      "default": "4.9 (+174 Reseñas verificadas)"
    },
    {
      "type": "text",
      "id": "save_text",
      "label": "Texto de 'Ahorras'",
      "default": "AHORRAS"
    },
    {
      "type": "text",
      "id": "discount_badge_text",
      "label": "Etiqueta Extra de Descuento (ej. Envío Gratis)",
      "default": "Envío Gratis"
    },
    {
      "type": "header",
      "content": "Textos de Ofertas de Volumen"
    },
    {
      "type": "text",
      "id": "offer_title_main",
      "label": "Título Principal de Ofertas",
      "default": "Compra más, gasta menos"
    },
    {
      "type": "text",
      "id": "offer_1_title",
      "label": "Título Oferta 1 (1x)",
      "default": "Compra 1"
    },
    {
      "type": "text",
      "id": "offer_1_subtitle",
      "label": "Subtítulo Oferta 1",
      "default": "Precio Normal"
    },
    {
      "type": "text",
      "id": "offer_2_badge",
      "label": "Insignia Oferta 2",
      "default": "MÁS POPULAR"
    },
    {
      "type": "text",
      "id": "offer_2_title",
      "label": "Título Oferta 2 (2x)",
      "default": "Compra 2"
    },
    {
      "type": "text",
      "id": "offer_2_subtitle",
      "label": "Subtítulo Oferta 2",
      "default": "Ahorras 20% en total"
    },
    {
      "type": "text",
      "id": "offer_3_badge",
      "label": "Insignia Oferta 3",
      "default": "MEJOR VALOR"
    },
    {
      "type": "text",
      "id": "offer_3_title",
      "label": "Título Oferta 3 (3x)",
      "default": "Compra 3"
    },
    {
      "type": "text",
      "id": "offer_3_subtitle",
      "label": "Subtítulo Oferta 3",
      "default": "Ahorras 30% en total"
    },
    {
      "type": "header",
      "content": "Botón de Compra y Pagos"
    },
    {
      "type": "text",
      "id": "add_to_cart_text",
      "label": "Texto del botón Agregar al Carrito",
      "default": "AGREGAR AL CARRITO"
    },
    {
      "type": "text",
      "id": "payment_trust_title",
      "label": "Título de Pasarelas de Pago",
      "default": "MÁS OPCIONES DE PAGO"
    },
    {
      "type": "header",
      "content": "Línea de Tiempo de Envío"
    },
    {
      "type": "text",
      "id": "shipping_step_1",
      "label": "Paso 1",
      "default": "Pedido realizado"
    },
    {
      "type": "text",
      "id": "shipping_step_2",
      "label": "Paso 2",
      "default": "Pedido listo"
    },
    {
      "type": "text",
      "id": "shipping_step_3",
      "label": "Paso 3",
      "default": "Pedido entregado"
    },
    {
      "type": "header",
      "content": "Testimonio Inferior"
    },
    {
      "type": "textarea",
      "id": "testimonial_text",
      "label": "Cita del Testimonio",
      "default": "\"Se los compré a mi hija y está enamorada. Calidad 10/10, la cancelación de ruido es una maravilla y la batería dura días.\""
    },
    {
      "type": "text",
      "id": "testimonial_author",
      "label": "Autor del Testimonio",
      "default": "Carla T. ★★★★★"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Viñeta / Característica",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto de la característica",
          "default": "Nueva característica"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Color del Icono",
          "default": "#10b981"
        }
      ]
    },
    {
      "type": "payment_icon",
      "name": "Icono de Pago Personalizado",
      "limit": 10,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Sube tu icono de pago (ej. Bancolombia, Nequi, etc.)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Producto Principal (Dinámico)"
    }
  ]
}
{% endschema %}
