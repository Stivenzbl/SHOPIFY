<section class="results-section">
  <div class="container">
    <div class="results-grid">
      
      <div class="results-content">
        <h2 class="section-title" style="text-align: left; margin-bottom: 20px;">Nuestros Resultados</h2>
        <p>Hablamos sobre los resultados de nuestros clientes y cómo ZBC Max ha mejorado su experiencia diaria de audio, trabajo y relajación.</p>
        <div style="margin-top: 30px;">
          <a href="#landing-add-to-cart-form" class="add-to-cart-btn" style="display: inline-block; text-align: center; text-transform: uppercase; width: auto; padding: 14px 35px;">Obtener Oferta Hoy</a>
        </div>
      </div>
      
      <div class="result-bars-list">
        <!-- Resultado 1: 96% -->
        <div class="result-bar-item glass-panel">
          <div class="progress-circle">
            <svg>
              <circle class="bg-circle" cx="35" cy="35" r="32"></circle>
              <circle class="val-circle" cx="35" cy="35" r="32" style="stroke-dashoffset: 8;"></circle> <!-- 201 * (1 - 0.96) = 8 -->
            </svg>
            <div class="progress-circle-text">96%</div>
          </div>
          <div class="result-bar-text">
            <strong>Calidad de Sonido Excelente:</strong> "He notado que la nitidez del audio y la respuesta de graves ha superado con creces mis expectativas diarias."
          </div>
        </div>
        
        <!-- Resultado 2: 92% -->
        <div class="result-bar-item glass-panel">
          <div class="progress-circle">
            <svg>
              <circle class="bg-circle" cx="35" cy="35" r="32"></circle>
              <circle class="val-circle" cx="35" cy="35" r="32" style="stroke-dashoffset: 16;"></circle> <!-- 201 * (1 - 0.92) = 16 -->
            </svg>
            <div class="progress-circle-text">92%</div>
          </div>
          <div class="result-bar-text">
            <strong>Cancelación de Ruido Efectiva:</strong> "Me permite concentrarme por completo en la oficina o durante los viajes de forma instantánea."
          </div>
        </div>
        
        <!-- Resultado 3: 95% -->
        <div class="result-bar-item glass-panel">
          <div class="progress-circle">
            <svg>
              <circle class="bg-circle" cx="35" cy="35" r="32"></circle>
              <circle class="val-circle" cx="35" cy="35" r="32" style="stroke-dashoffset: 10;"></circle> <!-- 201 * (1 - 0.95) = 10 -->
            </svg>
            <div class="progress-circle-text">95%</div>
          </div>
          <div class="result-bar-text">
            <strong>Confort y Ergonomía:</strong> "Las almohadillas de espuma viscoelástica son extremadamente cómodas para usar durante horas seguidas."
          </div>
        </div>
        
      </div>
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Results Section",
  "settings": []
}
{% endschema %}
